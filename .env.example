# Aliyun Model Studio / Bailian API key.
DASHSCOPE_API_KEY=sk-your-api-key

# The official docs use a workspace-region endpoint:
# https://{WorkspaceId}.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
# You can either set DASHSCOPE_BASE_URL directly or set workspace + region.
DASHSCOPE_BASE_URL=
DASHSCOPE_WORKSPACE_ID=
DASHSCOPE_REGION=cn-beijing

# Main video understanding model. Good for large shot-by-shot visual reports.
ALIYUN_VISION_MODEL=qwen3.7-plus

# Audio/dialogue specialist. Use when the sound/music/dialogue column matters.
ALIYUN_OMNI_MODEL=qwen3.5-omni-plus

# Optional: Codex Agent defaults. Leave blank to follow the local Codex config.
CODEX_MODEL=
CODEX_REASONING_EFFORT=

# Local platform port.
PORT=5177

# Optional: Aliyun OSS upload config for generating public/signed video URLs.
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_REGION=oss-cn-beijing
OSS_BUCKET=
OSS_ENDPOINT=
OSS_PREFIX=video-agent
OSS_SIGNED_URL_EXPIRES=86400

# Optional: GitHub Releases upload config for temporary public URLs.
# The repository should be public if the model needs to read browser_download_url.
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_RELEASE_TAG=video-agent-temp
GITHUB_RELEASE_NAME=Video Agent Temporary Uploads
GITHUB_ASSET_PREFIX=video-agent
