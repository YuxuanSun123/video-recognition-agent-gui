{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Shot Reader",
  "version": "0.2.0",
  "identifier": "com.videoagent.shotreader",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5177",
    "beforeBuildCommand": "npm run build:sidecar && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Shot Reader",
        "width": 1480,
        "height": 920,
        "minWidth": 1220,
        "minHeight": 780,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/backend-sidecar"
    ]
  }
}
